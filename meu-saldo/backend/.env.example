APP_NAME=MeuSaldo
APP_ENV=development
APP_DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meusaldodb
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meusaldodb
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-me-in-development
