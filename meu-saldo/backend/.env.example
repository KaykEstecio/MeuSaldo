JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_COOKIE_NAME=meusaldo_refresh
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax
AI_PROVIDER=rules
AI_API_KEY=
OPENAI_API_KEY=
