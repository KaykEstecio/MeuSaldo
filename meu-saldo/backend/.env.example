AI_CONTEXT_MESSAGES=6
AI_MONTHLY_TOKEN_BUDGET=0
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AI_REQUESTS=20
